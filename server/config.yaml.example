server:
  port: 8080
  context_path: /api

database:
  host: localhost
  port: 3306
  name: ai_comic_generator
  user: root
  password:  # 请填写实际密码
  max_idle_conns: 10
  max_open_conns: 100

redis:
  host: localhost
  port: 6379
  db: 0
  password: ""

session:
  secret: "mason"
  max_age: 2592000

log:
  level: info
  file_path: ""

# 步骤 1–3：通义千问 qwen-plus（LangChainGo OpenAI 兼容）
ai:
  dashscope:
    api_key: "sk-xxx"
    model: "qwen-plus"
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  # 步骤 4：腾讯混元生图（未配置时开发模式用占位图）
  hunyuan:
    enabled: false
    secret_id: ""
    secret_key: ""
    region: "ap-guangzhou"
    model: "hunyuan-image"

# 漫画图片本地存储（步骤 4–5 输出）
storage:
  base_path: "./data/comics"
  public_url: "/static/comics"

# 步骤 6：微信公众号（未配置时仅标记 DRAFT）
wechat:
  enabled: false
  app_id: ""
  app_secret: ""
