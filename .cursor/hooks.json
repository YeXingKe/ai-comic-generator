{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-after-edit.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/lint-before-commit.sh",
        "matcher": "git\\s+commit",
        "failClosed": false
      }
    ]
  }
}
