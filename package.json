{
  "name": "ai-comic-generator",
  "version": "1.0.0",
  "private": true,
  "description": "AI comic generator monorepo - web frontend + Go backend",
  "scripts": {
    "dev": "concurrently -n web,server -c blue,magenta \"npm run dev:web\" \"npm run dev:server\"",
    "web": "npm run dev --prefix web",
    "server": "go run -C server ./cmd/server/main.go",
    "build:web": "npm run build --prefix web",
    "build:server": "go build -C server -o ../bin/server ./cmd/server/main.go",
    "install:web": "npm install --prefix web",
    "prepare": "husky",
    "commitlint": "commitlint"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "concurrently": "^9.2.3",
    "husky": "^9.1.7"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
